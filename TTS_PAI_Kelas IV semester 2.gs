========== BAB 10 ===================== -->\n<div class="wrap" style="margin-top:32px">\n  <div class="hdr">\n    <h1>Teka-Teki Silang — Bab 10 PAI Kelas 4</h1>\n    <p>Kisah Nabi Muhammad saw. Membangun Kota Madinah</p>\n  </div>\n  <div class="body">\n    <div class="grid-side">\n      <table class="tts" id="tbl10"></table>\n      <div class="btns">\n        <button class="primary" onclick="cek10()">Cek Jawaban</button>\n        <button onclick="resetGrid10()">Reset</button>\n        \n      </div>\n      <div class="status" id="st10"></div>\n      <div class="win" id="win10">&#127881; Selamat! Semua jawaban benar!</div>\n    </div>\n    <div class="clue-side">\n      <div class="sec"><div class="cs-title">Mendatar &rarr;</div><div id="ca10"></div></div>\n      <div class="sec"><div class="cs-title">Menurun &darr;</div><div id="cd10"></div></div>\n    </div>\n  </div>\n</div>\n\n<script>\nfunction buildTTS(cfg){\n  var R=13,C=13;\n  var wordDefs=cfg.words, tblId=cfg.tblId, prefix=cfg.prefix;\n  var gd=[];\n  for(var i=0;i<R;i++){gd.push([]);for(var j=0;j<C;j++) gd[i].push(null);}\n  wordDefs.forEach(function(w){\n    for(var i=0;i<w.w.length;i++){\n      var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;\n      if(!gd[r][c]) gd[r][c]={letter:w.w[i]};\n      else gd[r][c].letter=w.w[i];\n    }\n  });\n  var startCells={};\n  wordDefs.forEach(function(w){startCells[w.r+\',\'+w.c]=true;});\n  var cellNum=[];\n  for(var i=0;i<R;i++){cellNum.push([]);for(var j=0;j<C;j++) cellNum[i].push(0);}\n  var counter=1;\n  for(var r=0;r<R;r++) for(var c=0;c<C;c++) if(startCells[r+\',\'+c]) cellNum[r][c]=counter++;\n  var words=[];\n  wordDefs.forEach(function(wd){\n    var num=cellNum[wd.r][wd.c];\n    if(num>0) words.push({id:num,w:wd.w,r:wd.r,c:wd.c,d:wd.d,q:wd.q});\n  });\n  var wordsA=words.filter(function(w){return w.d===\'A\';}).sort(function(a,b){return a.id-b.id;});\n  var wordsD=words.filter(function(w){return w.d===\'D\';}).sort(function(a,b){return a.id-b.id;});\n\n  var tbl=document.getElementById(tblId);\n  for(var r=0;r<R;r++){\n    var tr=document.createElement(\'tr\');\n    for(var c=0;c<C;c++){\n      var td=document.createElement(\'td\');\n      if(!gd[r][c]){td.className=\'blk\';}\n      else{\n        if(cellNum[r][c]>0){var sp=document.createElement(\'span\');sp.className=\'cnum\';sp.textContent=cellNum[r][c];td.appendChild(sp);}\n        var inp=document.createElement(\'input\');inp.type=\'text\';inp.maxLength=1;\n        (function(rr,cc){\n          inp.addEventListener(\'mousedown\',function(e){e.preventDefault();sc(rr,cc);this.focus();});\n          inp.addEventListener(\'keydown\',function(e){ok(e,rr,cc);});\n          inp.addEventListener(\'input\',function(e){oi(e,rr,cc);});\n        })(r,c);\n        td.appendChild(inp);\n      }\n      tr.appendChild(td);\n    }\n    tbl.appendChild(tr);\n  }\n\n  var aw=null,adir=\'A\',ar=0,ac=0;\n  function gi(r,c){return document.querySelector(\'#\'+tblId+\' tr:nth-child(\'+(r+1)+\') td:nth-child(\'+(c+1)+\') input\');}\n  function gt(r,c){return document.querySelector(\'#\'+tblId+\' tr:nth-child(\'+(r+1)+\') td:nth-child(\'+(c+1)+\')\');}\n  function wa(r,c,dir){\n    for(var i=0;i<words.length;i++){var w=words[i];if(w.d!==dir) continue;for(var j=0;j<w.w.length;j++){var wr=w.d===\'A\'?w.r:w.r+j,wc=w.d===\'A\'?w.c+j:w.c;if(wr===r&&wc===c) return w;}}return null;\n  }\n  function sc(r,c,dir){\n    if(!gd[r]||!gd[r][c]) return;\n    var d=dir||adir,w=wa(r,c,d);\n    if(!w){d=d===\'A\'?\'D\':\'A\';w=wa(r,c,d);}\n    if(!w) return;\n    if(aw&&aw.id===w.id&&aw.d===w.d&&ar===r&&ac===c){var nd=adir===\'A\'?\'D\':\'A\';var nw=wa(r,c,nd);if(nw){w=nw;d=nd;}}\n    aw=w;adir=d;ar=r;ac=c;hl();hlc();\n    var inp=gi(r,c);if(inp) inp.focus();\n  }\n  function hl(){\n    document.querySelectorAll(\'#\'+tblId+\' td\').forEach(function(td){td.classList.remove(\'hl-word\',\'hl-cur\');});\n    if(!aw) return;\n    for(var i=0;i<aw.w.length;i++){var r=aw.d===\'A\'?aw.r:aw.r+i,c=aw.d===\'A\'?aw.c+i:aw.c;var td=gt(r,c);if(td) td.classList.add(\'hl-word\');}\n    var td=gt(ar,ac);if(td){td.classList.remove(\'hl-word\');td.classList.add(\'hl-cur\');}\n  }\n  function hlc(){\n    document.querySelectorAll(\'#ca\'+prefix+\' .ci,#cd\'+prefix+\' .ci\').forEach(function(el){el.classList.remove(\'act\');});\n    if(aw){var el=document.getElementById(\'ci\'+prefix+\'-\'+aw.id+aw.d);if(el){el.classList.add(\'act\');el.scrollIntoView({block:\'nearest\'});}}\n  }\n  function oi(e,r,c){var inp=e.target;inp.value=inp.value.toUpperCase().replace(/[^A-Z]/g,\'\');if(inp.value) mn(r,c);}\n  function ok(e,r,c){\n    if(e.key===\'Backspace\'){var inp=gi(r,c);var td=gt(r,c);if(inp&&inp.value===\'\') mp(r,c);else if(inp){inp.value=\'\';if(td) td.classList.remove(\'ok-cell\',\'no-cell\');}e.preventDefault();}\n    else if(e.key===\'ArrowRight\'){if(c+1<C&&gd[r][c+1]) sc(r,c+1,\'A\');e.preventDefault();}\n    else if(e.key===\'ArrowLeft\'){if(c-1>=0&&gd[r][c-1]) sc(r,c-1,\'A\');e.preventDefault();}\n    else if(e.key===\'ArrowDown\'){if(r+1<R&&gd[r+1]&&gd[r+1][c]) sc(r+1,c,\'D\');e.preventDefault();}\n    else if(e.key===\'ArrowUp\'){if(r-1>=0&&gd[r-1]&&gd[r-1][c]) sc(r-1,c,\'D\');e.preventDefault();}\n    else if(e.key===\'Tab\'){e.preventDefault();cw(e.shiftKey);}\n  }\n  function ii(w,r,c){for(var i=0;i<w.w.length;i++){var wr=w.d===\'A\'?w.r:w.r+i,wc=w.d===\'A\'?w.c+i:w.c;if(wr===r&&wc===c) return i;}return -1;}\n  function mn(r,c){if(!aw) return;var idx=ii(aw,r,c);if(idx<0||idx>=aw.w.length-1) return;var nr=aw.d===\'A\'?aw.r:aw.r+idx+1,nc=aw.d===\'A\'?aw.c+idx+1:aw.c;sc(nr,nc,aw.d);}\n  function mp(r,c){if(!aw) return;var idx=ii(aw,r,c);if(idx<=0) return;var nr=aw.d===\'A\'?aw.r:aw.r+idx-1,nc=aw.d===\'A\'?aw.c+idx-1:aw.c;sc(nr,nc,aw.d);}\n  function cw(prev){var all=wordsA.concat(wordsD);var idx=0;for(var i=0;i<all.length;i++){if(aw&&all[i].id===aw.id&&all[i].d===aw.d){idx=i;break;}}var nx=prev?(idx-1+all.length)%all.length:(idx+1)%all.length;sc(all[nx].r,all[nx].c,all[nx].d);}\n\n  var ca=document.getElementById(\'ca\'+prefix),cd=document.getElementById(\'cd\'+prefix);\n  wordsA.forEach(function(w){var el=document.createElement(\'div\');el.className=\'ci\';el.id=\'ci\'+prefix+\'-\'+w.id+w.d;el.innerHTML=\'<b>\'+w.id+\'.</b>\'+w.q;el.addEventListener(\'click\',function(){sc(w.r,w.c,w.d);});ca.appendChild(el);});\n  wordsD.forEach(function(w){var el=document.createElement(\'div\');el.className=\'ci\';el.id=\'ci\'+prefix+\'-\'+w.id+w.d;el.innerHTML=\'<b>\'+w.id+\'.</b>\'+w.q;el.addEventListener(\'click\',function(){sc(w.r,w.c,w.d);});cd.appendChild(el);});\n\n  window[\'cek\'+prefix]=function(){\n    var benar=0;\n    words.forEach(function(w){var ok=true;for(var i=0;i<w.w.length;i++){var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;var inp=gi(r,c);var td=gt(r,c);if(inp&&td){td.classList.remove(\'ok-cell\',\'no-cell\');if((inp.value||\'\').toUpperCase()===w.w[i]) td.classList.add(\'ok-cell\');else{td.classList.add(\'no-cell\');ok=false;}}}\n    var ci=document.getElementById(\'ci\'+prefix+\'-\'+w.id+w.d);if(ok){benar++;if(ci) ci.classList.add(\'done\');}else if(ci) ci.classList.remove(\'done\');});\n    var st=document.getElementById(\'st\'+prefix);st.style.display=\'block\';st.textContent=\'Benar: \'+benar+\' dari \'+words.length+\' kata\';\n    document.getElementById(\'win\'+prefix).style.display=benar===words.length?\'block\':\'none\';\n  };\n  window[\'resetGrid\'+prefix]=function(){\n    document.querySelectorAll(\'#\'+tblId+\' input\').forEach(function(i){i.value=\'\';});\n    document.querySelectorAll(\'#\'+tblId+\' td\').forEach(function(td){td.classList.remove(\'ok-cell\',\'no-cell\',\'hl-word\',\'hl-cur\');});\n    document.querySelectorAll(\'#ca\'+prefix+\' .ci,#cd\'+prefix+\' .ci\').forEach(function(el){el.classList.remove(\'done\');});\n    document.getElementById(\'st\'+prefix).style.display=\'none\';document.getElementById(\'win\'+prefix).style.display=\'none\';\n    aw=null;sc(words[0].r,words[0].c,words[0].d);\n  };\n  window[\'buka\'+prefix]=function(){\n    words.forEach(function(w){for(var i=0;i<w.w.length;i++){var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;var inp=gi(r,c);var td=gt(r,c);if(inp) inp.value=w.w[i];if(td){td.classList.remove(\'no-cell\');td.classList.add(\'ok-cell\');}}\n    var ci=document.getElementById(\'ci\'+prefix+\'-\'+w.id+w.d);if(ci) ci.classList.add(\'done\');});\n    var st=document.getElementById(\'st\'+prefix);st.style.display=\'block\';st.textContent=\'Semua jawaban ditampilkan\';\n  };\n  sc(words[0].r,words[0].c,words[0].d);\n}\n\n// BAB 8\nbuildTTS({tblId:\'tbl8\',prefix:\'8\',words:[\n  {w:\'SALAM\',     r:0,  c:0,  d:\'A\', q:\'Ucapan assalamualaikum; artinya damai dan pernyataan hormat\'},\n  {w:\'MUNAFIK\',   r:0,  c:6,  d:\'A\', q:\'Orang yang bermuka dua; berpura-pura beriman\'},\n  {w:\'JUJUR\',     r:2,  c:0,  d:\'A\', q:\'Lurus hati, tidak berbohong, berkata apa adanya\'},\n  {w:\'AMANAH\',    r:2,  c:6,  d:\'A\', q:\'Sesuatu yang dipercayakan atau dititipkan; dapat dipercaya\'},\n  {w:\'MENOLONG\',  r:4,  c:0,  d:\'A\', q:\'Sikap saling membantu dalam kebaikan dan takwa\'},\n  {w:\'DUSTA\',     r:4,  c:10, d:\'A\', q:\'Ciri munafik pertama: berkata tidak jujur (bohong)\'},\n  {w:\'DAMAI\',     r:6,  c:0,  d:\'A\', q:\'Arti kata salam; tujuan menyebarkan salam\'},\n  {w:\'KHIANAT\',   r:8,  c:0,  d:\'A\', q:\'Ciri munafik ketiga: mengingkari kepercayaan yang diberikan\'},\n  {w:\'SALEH\',     r:10, c:0,  d:\'A\', q:\'Anak yang berperilaku baik dan meneladani akhlak Rasul\'},\n  {w:\'INSYAALLAH\',r:12, c:0,  d:\'A\', q:\'Ucapan saat berjanji: jika Allah berkehendak\'},\n  {w:\'SUNAH\',     r:0,  c:0,  d:\'D\', q:\'Hukum mengucapkan salam: wajib dijawab, hukum mengucapkan adalah ...\'},\n  {w:\'JANJI\',     r:0,  c:4,  d:\'D\', q:\'Ciri munafik kedua: jika berjanji ia mengingkari ...\'},\n  {w:\'MUSLIM\',    r:0,  c:6,  d:\'D\', q:\'Orang yang memeluk agama Islam\'},\n  {w:\'AKHLAK\',    r:2,  c:2,  d:\'D\', q:\'Agama adalah ... yang