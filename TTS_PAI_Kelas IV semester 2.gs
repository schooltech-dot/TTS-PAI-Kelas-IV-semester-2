function doGet() {
  var html = '<!DOCTYPE html>\n<html lang="id">\n<head>\n<meta charset="UTF-8">\n<meta name="viewport" content="width=device-width, initial-scale=1.0">\n<title>TTS Bab 6 PAI Kelas 4</title>\n<style>\n*{box-sizing:border-box;margin:0;padding:0}\nbody{font-family:\'Segoe UI\',Arial,sans-serif;background:#1a1f2e;min-height:100vh;padding:24px}\n.wrap{max-width:960px;margin:0 auto;background:#242b3d;border-radius:14px;padding:28px;border:1px solid #2e3a52}\n.hdr{text-align:center;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #2e3a52}\n.hdr h1{font-size:20px;font-weight:700;color:#7ecfb3}\n.hdr p{font-size:12.5px;color:#a0aec0;margin-top:4px}\n.body{display:flex;gap:28px;align-items:flex-start}\n.grid-side{flex:0 0 auto}\ntable.tts{border-collapse:collapse;border:3px solid #111}\ntable.tts td{width:34px;height:34px;padding:0;position:relative;border:2px solid #111;background:#fff}\ntable.tts td.blk{background:#111;border-color:#111}\n.cnum{position:absolute;top:2px;left:3px;font-size:8px;line-height:1;color:#111;pointer-events:none;z-index:2;font-weight:700}\ntable.tts td input{display:block;width:100%;height:100%;border:none;outline:none;background:transparent;text-align:center;font-size:14px;font-weight:700;text-transform:uppercase;color:#111;cursor:pointer;padding:0;font-family:\'Segoe UI\',Arial,sans-serif}\ntable.tts td.hl-word{background:#dff0ea}\ntable.tts td.hl-cur{background:#7ecfb3}\ntable.tts td.ok-cell{background:#c8ecd8!important}\ntable.tts td.no-cell{background:#e83535!important;color:#fff!important}\n.clue-side{flex:1;min-width:220px;background:#f0f4f8;border-radius:10px;padding:16px;border:1px solid #d0dae8}\n.cs-title{font-size:11px;font-weight:700;color:#2a6a58;letter-spacing:.1em;text-transform:uppercase;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #7ecfb3}\n.ci{font-size:12.5px;color:#1a2a3a;padding:5px 8px;border-radius:6px;cursor:pointer;margin-bottom:3px;border:1px solid transparent;line-height:1.5}\n.ci:hover{background:#ddeef8;border-color:#aacce8}\n.ci.act{background:#c8e8f8;color:#0a3a6a;border-color:#7ab8e0;font-weight:600}\n.ci.done{color:#4a8a60;text-decoration:line-through;opacity:.6}\n.ci b{font-weight:700;margin-right:5px;color:#2a6a58}\n.ci.act b{color:#0a5a8a}\n.sec{margin-bottom:16px}\n.btns{display:flex;gap:10px;margin-top:16px;flex-wrap:wrap}\n.btns button{font-size:12.5px;padding:7px 16px;border-radius:8px;border:1px solid #3a4a66;background:#1e2535;color:#c0cce0;cursor:pointer;font-family:\'Segoe UI\',Arial,sans-serif;font-weight:500}\n.btns button:hover{background:#2a3550;color:#e0eaf8}\n.btns button.primary{background:#2a6a58;color:#a0e8c8;border-color:#3a8a70}\n.btns button.primary:hover{background:#306a58}\n.status{font-size:13px;color:#a0aec0;margin-top:10px;padding:7px 12px;background:#1e2535;border-radius:7px;border:1px solid #2e3a52;display:none}\n.win{display:none;font-size:13px;font-weight:600;color:#7ecfb3;background:#1a3530;border-radius:8px;padding:10px 14px;margin-top:10px;border:1px solid #3a8a70}\n</style>\n</head>\n<body>\n<div class="wrap">\n  <div class="hdr">\n    <h1>Teka-Teki Silang — Bab 6 PAI Kelas 4</h1>\n    <p>Q.S. At-Tīn &amp; Hadis tentang Silaturahmi</p>\n  </div>\n  <div class="body">\n    <div class="grid-side">\n      <table class="tts" id="tbl"></table>\n      <div class="btns">\n        <button class="primary" onclick="cek()">Cek Jawaban</button>\n        <button onclick="resetGrid()">Reset</button>\n        \n      </div>\n      <div class="status" id="st"></div>\n      <div class="win" id="win">&#127881; Selamat! Semua jawaban benar!</div>\n    </div>\n    <div class="clue-side">\n      <div class="sec">\n        <div class="cs-title">Mendatar &rarr;</div>\n        <div id="ca"></div>\n      </div>\n      <div class="sec">\n        <div class="cs-title">Menurun &darr;</div>\n        <div id="cd"></div>\n      </div>\n    </div>\n  </div>\n</div>\n<script>\nvar R=13, C=13;\n\nvar wordDefs=[\n  {w:\'TIN\',        r:0,  c:0,  d:\'A\', q:\'Nama buah pada judul surah ke-95 Al-Quran\'},\n  {w:\'ZAITUN\',     r:0,  c:4,  d:\'A\', q:\'Buah yang disebut bersama tin dalam sumpah Allah (ayat 1)\'},\n  {w:\'MAKKIYAH\',   r:2,  c:0,  d:\'A\', q:\'Golongan surah yang diturunkan sebelum hijrah\'},\n  {w:\'SINAI\',      r:4,  c:1,  d:\'A\', q:\'Gunung tempat Nabi Musa bermunajat kepada Allah\'},\n  {w:\'SILATURAHMI\',r:6,  c:0,  d:\'A\', q:\'Tali persaudaraan yang diperintahkan Nabi saw\'},\n  {w:\'NERAKA\',     r:8,  c:2,  d:\'A\', q:\'Tempat serendah-rendahnya bagi yang durhaka kepada Allah\'},\n  {w:\'AKAL\',       r:10, c:0,  d:\'A\', q:\'Kelebihan manusia yang tidak dimiliki hewan\'},\n  {w:\'HAKIM\',      r:10, c:6,  d:\'A\', q:\'Sebutan Allah dalam ayat 8: "Bukankah Allah ___ yang paling adil"\'},\n  {w:\'TARTIL\',     r:12, c:4,  d:\'A\', q:\'Cara membaca Al-Quran dengan memperhatikan tajwid\'},\n  {w:\'TAQWIM\',     r:0,  c:0,  d:\'D\', q:\'"Ahsani ___" artinya bentuk yang sebaik-baiknya (ayat 4)\'},\n  {w:\'ISA\',        r:0,  c:4,  d:\'D\', q:\'Nabi yang diutus di wilayah Syam/Palestina\'},\n  {w:\'MUSA\',       r:0,  c:9,  d:\'D\', q:\'Nabi yang bermunajat di Gunung Sinai Mesir\'},\n  {w:\'AMAL\',       r:2,  c:2,  d:\'D\', q:\'Perbuatan baik yang mendatangkan pahala tidak putus-putusnya\'},\n  {w:\'IMAN\',       r:4,  c:6,  d:\'D\', q:\'Syarat selamat dari neraka menurut ayat 6 At-Tin\'},\n  {w:\'PAHALA\',     r:6,  c:10, d:\'D\', q:\'Balasan tidak putus-putusnya bagi orang beriman dan beramal saleh\'},\n];\n\n// Bangun grid dari definisi kata\nvar gd=[];\nfor(var i=0;i<R;i++){gd.push([]);for(var j=0;j<C;j++) gd[i].push(null);}\nwordDefs.forEach(function(w){\n  for(var i=0;i<w.w.length;i++){\n    var r=w.d===\'A\'?w.r:w.r+i, c=w.d===\'A\'?w.c+i:w.c;\n    if(!gd[r][c]) gd[r][c]={letter:w.w[i]};\n    else gd[r][c].letter=w.w[i];\n  }\n});\n\n// Kumpulkan semua posisi awal kata yang valid\nvar startCells={}; // key "r,c" -> true\nwordDefs.forEach(function(w){\n  var key=w.r+\',\'+w.c;\n  startCells[key]=true;\n});\n\n// Nomori posisi awal urut atas-bawah kiri-kanan\nvar cellNum=[];\nfor(var i=0;i<R;i++){cellNum.push([]);for(var j=0;j<C;j++) cellNum[i].push(0);}\nvar counter=1;\nfor(var r=0;r<R;r++){\n  for(var c=0;c<C;c++){\n    if(startCells[r+\',\'+c]){\n      cellNum[r][c]=counter++;\n    }\n  }\n}\n\n// Assign nomor ke kata\nvar words=[];\nwordDefs.forEach(function(wd){\n  var num=cellNum[wd.r][wd.c];\n  if(num>0) words.push({id:num, w:wd.w, r:wd.r, c:wd.c, d:wd.d, q:wd.q});\n});\n\nvar wordsA=words.filter(function(w){return w.d===\'A\';}).sort(function(a,b){return a.id-b.id;});\nvar wordsD=words.filter(function(w){return w.d===\'D\';}).sort(function(a,b){return a.id-b.id;});\n\n// Render grid\nvar tbl=document.getElementById(\'tbl\');\nfor(var r=0;r<R;r++){\n  var tr=document.createElement(\'tr\');\n  for(var c=0;c<C;c++){\n    var td=document.createElement(\'td\');\n    if(!gd[r][c]){td.className=\'blk\';}\n    else{\n      if(cellNum[r][c]>0){\n        var sp=document.createElement(\'span\');\n        sp.className=\'cnum\';sp.textContent=cellNum[r][c];td.appendChild(sp);\n      }\n      var inp=document.createElement(\'input\');\n      inp.type=\'text\';inp.maxLength=1;\n      (function(rr,cc){\n        inp.addEventListener(\'mousedown\',function(e){e.preventDefault();selCell(rr,cc);this.focus();});\n        inp.addEventListener(\'keydown\',function(e){onKey(e,rr,cc);});\n        inp.addEventListener(\'input\',function(e){onInp(e,rr,cc);});\n      })(r,c);\n      td.appendChild(inp);\n    }\n    tr.appendChild(td);\n  }\n  tbl.appendChild(tr);\n}\n\nvar aw=null,adir=\'A\',ar=0,ac=0;\nfunction getInp(r,c){return document.querySelector(\'#tbl tr:nth-child(\'+(r+1)+\') td:nth-child(\'+(c+1)+\') input\');}\nfunction getTd(r,c){return document.querySelector(\'#tbl tr:nth-child(\'+(r+1)+\') td:nth-child(\'+(c+1)+\')\');}\n\nfunction wordAt(r,c,dir){\n  for(var i=0;i<words.length;i++){\n    var w=words[i];if(w.d!==dir) continue;\n    for(var j=0;j<w.w.length;j++){\n      var wr=w.d===\'A\'?w.r:w.r+j,wc=w.d===\'A\'?w.c+j:w.c;\n      if(wr===r&&wc===c) return w;\n    }\n  }\n  return null;\n}\n\nfunction selCell(r,c,dir){\n  if(!gd[r]||!gd[r][c]) return;\n  var d=dir||adir;\n  var w=wordAt(r,c,d);\n  if(!w){d=d===\'A\'?\'D\':\'A\';w=wordAt(r,c,d);}\n  if(!w) return;\n  if(aw&&aw.id===w.id&&aw.d===w.d&&ar===r&&ac===c){\n    var nd=adir===\'A\'?\'D\':\'A\';var nw=wordAt(r,c,nd);\n    if(nw){w=nw;d=nd;}\n  }\n  aw=w;adir=d;ar=r;ac=c;\n  highlight();hlClue();\n  var inp=getInp(r,c);if(inp) inp.focus();\n}\n\nfunction highlight(){\n  document.querySelectorAll(\'.tts td\').forEach(function(td){td.classList.remove(\'hl-word\',\'hl-cur\');});\n  if(!aw) return;\n  for(var i=0;i<aw.w.length;i++){\n    var r=aw.d===\'A\'?aw.r:aw.r+i,c=aw.d===\'A\'?aw.c+i:aw.c;\n    var td=getTd(r,c);if(td) td.classList.add(\'hl-word\');\n  }\n  var td=getTd(ar,ac);\n  if(td){td.classList.remove(\'hl-word\');td.classList.add(\'hl-cur\');}\n}\n\nfunction hlClue(){\n  document.querySelectorAll(\'.ci\').forEach(function(el){el.classList.remove(\'act\');});\n  if(aw){var el=document.getElementById(\'ci-\'+aw.id+aw.d);if(el){el.classList.add(\'act\');el.scrollIntoView({block:\'nearest\'});}}\n}\n\nfunction onInp(e,r,c){\n  var inp=e.target;\n  inp.value=inp.value.toUpperCase().replace(/[^A-Z]/g,\'\');\n  if(inp.value) mvNext(r,c);\n}\n\nfunction onKey(e,r,c){\n  if(e.key===\'Backspace\'){\n    var inp=getInp(r,c);var td=getTd(r,c);\n    if(inp&&inp.value===\'\') mvPrev(r,c);\n    else if(inp){inp.value=\'\';if(td) td.classList.remove(\'ok-cell\',\'no-cell\');}\n    e.preventDefault();\n  } else if(e.key===\'ArrowRight\'){if(c+1<C&&gd[r][c+1]) selCell(r,c+1,\'A\');e.preventDefault();}\n    else if(e.key===\'ArrowLeft\'){if(c-1>=0&&gd[r][c-1]) selCell(r,c-1,\'A\');e.preventDefault();}\n    else if(e.key===\'ArrowDown\'){if(r+1<R&&gd[r+1]&&gd[r+1][c]) selCell(r+1,c,\'D\');e.preventDefault();}\n    else if(e.key===\'ArrowUp\'){if(r-1>=0&&gd[r-1]&&gd[r-1][c]) selCell(r-1,c,\'D\');e.preventDefault();}\n    else if(e.key===\'Tab\'){e.preventDefault();cycleW(e.shiftKey);}\n}\n\nfunction idxInWord(w,r,c){\n  for(var i=0;i<w.w.length;i++){\n    var wr=w.d===\'A\'?w.r:w.r+i,wc=w.d===\'A\'?w.c+i:w.c;\n    if(wr===r&&wc===c) return i;\n  }return -1;\n}\nfunction mvNext(r,c){\n  if(!aw) return;\n  var idx=idxInWord(aw,r,c);\n  if(idx<0||idx>=aw.w.length-1) return;\n  var nr=aw.d===\'A\'?aw.r:aw.r+idx+1,nc=aw.d===\'A\'?aw.c+idx+1:aw.c;\n  selCell(nr,nc,aw.d);\n}\nfunction mvPrev(r,c){\n  if(!aw) return;\n  var idx=idxInWord(aw,r,c);\n  if(idx<=0) return;\n  var nr=aw.d===\'A\'?aw.r:aw.r+idx-1,nc=aw.d===\'A\'?aw.c+idx-1:aw.c;\n  selCell(nr,nc,aw.d);\n}\nfunction cycleW(prev){\n  var all=wordsA.concat(wordsD);\n  var idx=0;\n  for(var i=0;i<all.length;i++){if(aw&&all[i].id===aw.id&&all[i].d===aw.d){idx=i;break;}}\n  var nx=prev?(idx-1+all.length)%all.length:(idx+1)%all.length;\n  selCell(all[nx].r,all[nx].c,all[nx].d);\n}\n\nvar ca=document.getElementById(\'ca\'),cd=document.getElementById(\'cd\');\nwordsA.forEach(function(w){\n  var el=document.createElement(\'div\');\n  el.className=\'ci\';el.id=\'ci-\'+w.id+w.d;\n  el.innerHTML=\'<b>\'+w.id+\'.</b>\'+w.q;\n  el.addEventListener(\'click\',function(){selCell(w.r,w.c,w.d);});\n  ca.appendChild(el);\n});\nwordsD.forEach(function(w){\n  var el=document.createElement(\'div\');\n  el.className=\'ci\';el.id=\'ci-\'+w.id+w.d;\n  el.innerHTML=\'<b>\'+w.id+\'.</b>\'+w.q;\n  el.addEventListener(\'click\',function(){selCell(w.r,w.c,w.d);});\n  cd.appendChild(el);\n});\n\nfunction cek(){\n  var benar=0;\n  words.forEach(function(w){\n    var ok=true;\n    for(var i=0;i<w.w.length;i++){\n      var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;\n      var inp=getInp(r,c);var td=getTd(r,c);\n      if(inp&&td){\n        td.classList.remove(\'ok-cell\',\'no-cell\');\n        if((inp.value||\'\').toUpperCase()===w.w[i]) td.classList.add(\'ok-cell\');\n        else{td.classList.add(\'no-cell\');ok=false;}\n      }\n    }\n    var ci=document.getElementById(\'ci-\'+w.id+w.d);\n    if(ok){benar++;if(ci) ci.classList.add(\'done\');}\n    else if(ci) ci.classList.remove(\'done\');\n  });\n  var st=document.getElementById(\'st\');\n  st.style.display=\'block\';\n  st.textContent=\'Benar: \'+benar+\' dari \'+words.length+\' kata\';\n  document.getElementById(\'win\').style.display=benar===words.length?\'block\':\'none\';\n}\n\nfunction resetGrid(){\n  document.querySelectorAll(\'.tts input\').forEach(function(i){i.value=\'\';});\n  document.querySelectorAll(\'.tts td\').forEach(function(td){td.classList.remove(\'ok-cell\',\'no-cell\',\'hl-word\',\'hl-cur\');});\n  document.querySelectorAll(\'.ci\').forEach(function(el){el.classList.remove(\'done\');});\n  document.getElementById(\'st\').style.display=\'none\';\n  document.getElementById(\'win\').style.display=\'none\';\n  aw=null;selCell(words[0].r,words[0].c,words[0].d);\n}\n\nfunction buka(){\n  words.forEach(function(w){\n    for(var i=0;i<w.w.length;i++){\n      var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;\n      var inp=getInp(r,c);var td=getTd(r,c);\n      if(inp) inp.value=w.w[i];\n      if(td){td.classList.remove(\'no-cell\');td.classList.add(\'ok-cell\');}\n    }\n    var ci=document.getElementById(\'ci-\'+w.id+w.d);if(ci) ci.classList.add(\'done\');\n  });\n  var st=document.getElementById(\'st\');st.style.display=\'block\';\n  st.textContent=\'Semua jawaban ditampilkan\';\n}\n\nwindow.addEventListener(\'load\',function(){selCell(words[0].r,words[0].c,words[0].d);});\n</script>\n</body>\n</html>\n\n<!-- ===================== BAB 7 ===================== -->\n<div class="wrap" style="margin-top:32px">\n  <div class="hdr">\n    <h1>Teka-Teki Silang — Bab 7 PAI Kelas 4</h1>\n    <p>Beriman kepada Rasul-Rasul Allah</p>\n  </div>\n  <div class="body">\n    <div class="grid-side">\n      <table class="tts" id="tbl7"></table>\n      <div class="btns">\n        <button class="primary" onclick="cek7()">Cek Jawaban</button>\n        <button onclick="resetGrid7()">Reset</button>\n        \n      </div>\n      <div class="status" id="st7"></div>\n      <div class="win" id="win7">&#127881; Selamat! Semua jawaban benar!</div>\n    </div>\n    <div class="clue-side">\n      <div class="sec">\n        <div class="cs-title">Mendatar &rarr;</div>\n        <div id="ca7"></div>\n      </div>\n      <div class="sec">\n        <div class="cs-title">Menurun &darr;</div>\n        <div id="cd7"></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\nvar R=13,C=13;\nvar wordDefs=[\n  {w:\'SIDIK\',      r:0,  c:0,  d:\'A\', q:\'Sifat wajib rasul: berucap dan bertingkah laku yang benar (jujur)\'},\n  {w:\'AMANAH\',     r:0,  c:6,  d:\'A\', q:\'Sifat wajib rasul: dapat dipercaya, tidak berkhianat\'},\n  {w:\'TABLIG\',     r:2,  c:0,  d:\'A\', q:\'Sifat wajib rasul: menyampaikan seluruh wahyu kepada umat\'},\n  {w:\'FATANAH\',    r:4,  c:0,  d:\'A\', q:\'Sifat wajib rasul: cerdas dan bijaksana\'},\n  {w:\'KIZIB\',      r:4,  c:8,  d:\'A\', q:\'Sifat mustahil rasul: lawan dari sidik (dusta)\'},\n  {w:\'KHIANAT\',    r:6,  c:0,  d:\'A\', q:\'Sifat mustahil rasul: lawan dari amanah\'},\n  {w:\'KITMAN\',     r:6,  c:8,  d:\'A\', q:\'Sifat mustahil rasul: menyembunyikan wahyu\'},\n  {w:\'BALADAH\',    r:8,  c:0,  d:\'A\', q:\'Sifat mustahil rasul: lawan dari fatanah (bodoh)\'},\n  {w:\'WAHYU\',      r:10, c:0,  d:\'A\', q:\'Pesan Allah yang diterima dan disampaikan rasul kepada umat\'},\n  {w:\'ULUL\',       r:10, c:6,  d:\'A\', q:\'Sebutan rasul dengan keteguhan hati kuat: rasul ___ azmi\'},\n  {w:\'RASUL\',      r:12, c:0,  d:\'A\', q:\'Utusan Allah yang wajib menyampaikan wahyu kepada manusia\'},\n  {w:\'STAF\',       r:0,  c:0,  d:\'D\', q:\'Singkatan empat sifat wajib rasul: Sidik, Tablig, Amanah, Fatanah\'},\n  {w:\'IMAN\',       r:0,  c:4,  d:\'D\', q:\'Percaya dengan sepenuh hati kepada rukun iman\'},\n  {w:\'NABI\',       r:0,  c:6,  d:\'D\', q:\'Lelaki pilihan Allah yang diberi wahyu untuk dirinya sendiri\'},\n  {w:\'MUHAMMAD\',   r:0,  c:12, d:\'D\', q:\'Rasul terakhir, penutup para nabi, utusan untuk seluruh alam\'},\n  {w:\'AKHLAK\',     r:4,  c:2,  d:\'D\', q:\'Tujuan diutusnya Rasul: menyempurnakan ___ manusia\'},\n  {w:\'KABAR\',      r:6,  c:8,  d:\'D\', q:\'Rasul diutus menyampaikan ___ gembira dan ___ buruk\'},\n];\n\nvar gd=[];\nfor(var i=0;i<R;i++){gd.push([]);for(var j=0;j<C;j++) gd[i].push(null);}\nwordDefs.forEach(function(w){\n  for(var i=0;i<w.w.length;i++){\n    var r=w.d===\'A\'?w.r:w.r+i, c=w.d===\'A\'?w.c+i:w.c;\n    if(!gd[r][c]) gd[r][c]={letter:w.w[i]};\n    else gd[r][c].letter=w.w[i];\n  }\n});\n\nvar startCells={};\nwordDefs.forEach(function(w){ startCells[w.r+\',\'+w.c]=true; });\n\nvar cellNum=[];\nfor(var i=0;i<R;i++){cellNum.push([]);for(var j=0;j<C;j++) cellNum[i].push(0);}\nvar counter=1;\nfor(var r=0;r<R;r++){\n  for(var c=0;c<C;c++){\n    if(startCells[r+\',\'+c]) cellNum[r][c]=counter++;\n  }\n}\n\nvar words=[];\nwordDefs.forEach(function(wd){\n  var num=cellNum[wd.r][wd.c];\n  if(num>0) words.push({id:num,w:wd.w,r:wd.r,c:wd.c,d:wd.d,q:wd.q});\n});\nvar wordsA=words.filter(function(w){return w.d===\'A\';}).sort(function(a,b){return a.id-b.id;});\nvar wordsD=words.filter(function(w){return w.d===\'D\';}).sort(function(a,b){return a.id-b.id;});\n\nvar tbl=document.getElementById(\'tbl7\');\nfor(var r=0;r<R;r++){\n  var tr=document.createElement(\'tr\');\n  for(var c=0;c<C;c++){\n    var td=document.createElement(\'td\');\n    if(!gd[r][c]){td.className=\'blk\';}\n    else{\n      if(cellNum[r][c]>0){\n        var sp=document.createElement(\'span\');\n        sp.className=\'cnum\';sp.textContent=cellNum[r][c];td.appendChild(sp);\n      }\n      var inp=document.createElement(\'input\');\n      inp.type=\'text\';inp.maxLength=1;\n      (function(rr,cc){\n        inp.addEventListener(\'mousedown\',function(e){e.preventDefault();selCell7(rr,cc);this.focus();});\n        inp.addEventListener(\'keydown\',function(e){onKey7(e,rr,cc);});\n        inp.addEventListener(\'input\',function(e){onInp7(e,rr,cc);});\n      })(r,c);\n      td.appendChild(inp);\n    }\n    tr.appendChild(td);\n  }\n  tbl.appendChild(tr);\n}\n\nvar aw=null,adir=\'A\',ar=0,ac=0;\nfunction getInp(r,c){return document.querySelector(\'#tbl7 tr:nth-child(\'+(r+1)+\') td:nth-child(\'+(c+1)+\') input\');}\nfunction getTd(r,c){return document.querySelector(\'#tbl7 tr:nth-child(\'+(r+1)+\') td:nth-child(\'+(c+1)+\')\');}\nfunction wordAt(r,c,dir){\n  for(var i=0;i<words.length;i++){\n    var w=words[i];if(w.d!==dir) continue;\n    for(var j=0;j<w.w.length;j++){\n      var wr=w.d===\'A\'?w.r:w.r+j,wc=w.d===\'A\'?w.c+j:w.c;\n      if(wr===r&&wc===c) return w;\n    }\n  }return null;\n}\nfunction selCell7(r,c,dir){\n  if(!gd[r]||!gd[r][c]) return;\n  var d=dir||adir;\n  var w=wordAt(r,c,d);\n  if(!w){d=d===\'A\'?\'D\':\'A\';w=wordAt(r,c,d);}\n  if(!w) return;\n  if(aw&&aw.id===w.id&&aw.d===w.d&&ar===r&&ac===c){\n    var nd=adir===\'A\'?\'D\':\'A\';var nw=wordAt(r,c,nd);\n    if(nw){w=nw;d=nd;}\n  }\n  aw=w;adir=d;ar=r;ac=c;\n  highlight7();hlClue7();\n  var inp=getInp(r,c);if(inp) inp.focus();\n}\nfunction highlight7(){\n  document.querySelectorAll(\'#tbl7 td\').forEach(function(td){td.classList.remove(\'hl-word\',\'hl-cur\');});\n  if(!aw) return;\n  for(var i=0;i<aw.w.length;i++){\n    var r=aw.d===\'A\'?aw.r:aw.r+i,c=aw.d===\'A\'?aw.c+i:aw.c;\n    var td=getTd(r,c);if(td) td.classList.add(\'hl-word\');\n  }\n  var td=getTd(ar,ac);\n  if(td){td.classList.remove(\'hl-word\');td.classList.add(\'hl-cur\');}\n}\nfunction hlClue7(){\n  document.querySelectorAll(\'#ca7 .ci,#cd7 .ci\').forEach(function(el){el.classList.remove(\'act\');});\n  if(aw){var el=document.getElementById(\'ci7-\'+aw.id+aw.d);if(el){el.classList.add(\'act\');el.scrollIntoView({block:\'nearest\'});}}\n}\nfunction onInp7(e,r,c){\n  var inp=e.target;inp.value=inp.value.toUpperCase().replace(/[^A-Z]/g,\'\');\n  if(inp.value) mvNext7(r,c);\n}\nfunction onKey7(e,r,c){\n  if(e.key===\'Backspace\'){\n    var inp=getInp(r,c);var td=getTd(r,c);\n    if(inp&&inp.value===\'\') mvPrev7(r,c);\n    else if(inp){inp.value=\'\';if(td) td.classList.remove(\'ok-cell\',\'no-cell\');}\n    e.preventDefault();\n  } else if(e.key===\'ArrowRight\'){if(c+1<C&&gd[r][c+1]) selCell7(r,c+1,\'A\');e.preventDefault();}\n    else if(e.key===\'ArrowLeft\'){if(c-1>=0&&gd[r][c-1]) selCell7(r,c-1,\'A\');e.preventDefault();}\n    else if(e.key===\'ArrowDown\'){if(r+1<R&&gd[r+1]&&gd[r+1][c]) selCell7(r+1,c,\'D\');e.preventDefault();}\n    else if(e.key===\'ArrowUp\'){if(r-1>=0&&gd[r-1]&&gd[r-1][c]) selCell7(r-1,c,\'D\');e.preventDefault();}\n    else if(e.key===\'Tab\'){e.preventDefault();cycleW7(e.shiftKey);}\n}\nfunction idxInWord(w,r,c){\n  for(var i=0;i<w.w.length;i++){\n    var wr=w.d===\'A\'?w.r:w.r+i,wc=w.d===\'A\'?w.c+i:w.c;\n    if(wr===r&&wc===c) return i;\n  }return -1;\n}\nfunction mvNext7(r,c){\n  if(!aw) return;var idx=idxInWord(aw,r,c);\n  if(idx<0||idx>=aw.w.length-1) return;\n  var nr=aw.d===\'A\'?aw.r:aw.r+idx+1,nc=aw.d===\'A\'?aw.c+idx+1:aw.c;\n  selCell7(nr,nc,aw.d);\n}\nfunction mvPrev7(r,c){\n  if(!aw) return;var idx=idxInWord(aw,r,c);\n  if(idx<=0) return;\n  var nr=aw.d===\'A\'?aw.r:aw.r+idx-1,nc=aw.d===\'A\'?aw.c+idx-1:aw.c;\n  selCell7(nr,nc,aw.d);\n}\nfunction cycleW7(prev){\n  var all=wordsA.concat(wordsD);\n  var idx=0;for(var i=0;i<all.length;i++){if(aw&&all[i].id===aw.id&&all[i].d===aw.d){idx=i;break;}}\n  var nx=prev?(idx-1+all.length)%all.length:(idx+1)%all.length;\n  selCell7(all[nx].r,all[nx].c,all[nx].d);\n}\n\nvar ca=document.getElementById(\'ca7\'),cd=document.getElementById(\'cd7\');\nwordsA.forEach(function(w){\n  var el=document.createElement(\'div\');el.className=\'ci\';el.id=\'ci7-\'+w.id+w.d;\n  el.innerHTML=\'<b>\'+w.id+\'.</b>\'+w.q;\n  el.addEventListener(\'click\',function(){selCell7(w.r,w.c,w.d);});\n  ca.appendChild(el);\n});\nwordsD.forEach(function(w){\n  var el=document.createElement(\'div\');el.className=\'ci\';el.id=\'ci7-\'+w.id+w.d;\n  el.innerHTML=\'<b>\'+w.id+\'.</b>\'+w.q;\n  el.addEventListener(\'click\',function(){selCell7(w.r,w.c,w.d);});\n  cd.appendChild(el);\n});\n\nwindow.cek7=function(){\n  var benar=0;\n  words.forEach(function(w){\n    var ok=true;\n    for(var i=0;i<w.w.length;i++){\n      var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;\n      var inp=getInp(r,c);var td=getTd(r,c);\n      if(inp&&td){\n        td.classList.remove(\'ok-cell\',\'no-cell\');\n        if((inp.value||\'\').toUpperCase()===w.w[i]) td.classList.add(\'ok-cell\');\n        else{td.classList.add(\'no-cell\');ok=false;}\n      }\n    }\n    var ci=document.getElementById(\'ci7-\'+w.id+w.d);\n    if(ok){benar++;if(ci) ci.classList.add(\'done\');}\n    else if(ci) ci.classList.remove(\'done\');\n  });\n  var st=document.getElementById(\'st7\');\n  st.style.display=\'block\';st.textContent=\'Benar: \'+benar+\' dari \'+words.length+\' kata\';\n  document.getElementById(\'win7\').style.display=benar===words.length?\'block\':\'none\';\n};\nwindow.resetGrid7=function(){\n  document.querySelectorAll(\'#tbl7 input\').forEach(function(i){i.value=\'\';});\n  document.querySelectorAll(\'#tbl7 td\').forEach(function(td){td.classList.remove(\'ok-cell\',\'no-cell\',\'hl-word\',\'hl-cur\');});\n  document.querySelectorAll(\'#ca7 .ci,#cd7 .ci\').forEach(function(el){el.classList.remove(\'done\');});\n  document.getElementById(\'st7\').style.display=\'none\';\n  document.getElementById(\'win7\').style.display=\'none\';\n  aw=null;selCell7(words[0].r,words[0].c,words[0].d);\n};\nwindow.buka7=function(){\n  words.forEach(function(w){\n    for(var i=0;i<w.w.length;i++){\n      var r=w.d===\'A\'?w.r:w.r+i,c=w.d===\'A\'?w.c+i:w.c;\n      var inp=getInp(r,c);var td=getTd(r,c);\n      if(inp) inp.value=w.w[i];\n      if(td){td.classList.remove(\'no-cell\');td.classList.add(\'ok-cell\');}\n    }\n    var ci=document.getElementById(\'ci7-\'+w.id+w.d);if(ci) ci.