{w:\'NABAWI\',    r:0,  c:0,  d:\'A\', q:\'Nama masjid yang pertama dibangun Rasul di Madinah: Masjid ...\'},\n  {w:\'HIJRAH\',    r:0,  c:7,  d:\'A\', q:\'Perpindahan Rasul dan sahabat dari Makkah ke Madinah\'},\n  {w:\'MUHAJIRIN\', r:2,  c:0,  d:\'A\', q:\'Orang-orang yang berhijrah dari Makkah ke Madinah\'},\n  {w:\'ANSAR\',     r:4,  c:0,  d:\'A\', q:\'Penduduk Madinah yang menolong kaum Muhajirin; artinya penolong\'},\n  {w:\'UKHUWAH\',   r:4,  c:6,  d:\'A\', q:\'Persaudaraan yang dijalin Rasul antara Muhajirin dan Ansar\'},\n  {w:\'MADINAH\',   r:6,  c:0,  d:\'A\', q:\'Kota tujuan hijrah Nabi Muhammad saw.\'},\n  {w:\'PIAGAM\',    r:6,  c:8,  d:\'A\', q:\'Perjanjian kerukunan antar penduduk Madinah: ... Madinah\'},\n  {w:\'QUBA\',      r:8,  c:0,  d:\'A\', q:\'Nama masjid pertama yang dibangun Rasul dalam perjalanan hijrah\'},\n  {w:\'GOTONG\',    r:8,  c:5,  d:\'A\', q:\'Cara membangun Masjid Nabawi: Rasul bersama sahabat ... royong\'},\n  {w:\'MAKKAH\',    r:10, c:0,  d:\'A\', q:\'Kota asal Nabi Muhammad saw. sebelum hijrah\'},\n  {w:\'TOLERAN\',   r:10, c:7,  d:\'A\', q:\'Sikap menghargai perbedaan suku, bahasa, dan agama\'},\n  {w:\'KURMA\',     r:12, c:0,  d:\'A\', q:\'Bahan tiang dan atap Masjid Nabawi yang pertama\'},\n  {w:\'MUSLIM\',    r:12, c:7,  d:\'A\', q:\'Orang beriman yang bersaudara satu sama lain\'},\n  {w:\'NABI\',      r:0,  c:0,  d:\'D\', q:\'Lelaki pilihan Allah yang diberi wahyu; diutus Allah\'},\n  {w:\'MASJID\',    r:0,  c:5,  d:\'D\', q:\'Langkah pertama Rasul di Madinah: membangun ...\'},\n  {w:\'HIJRAH\',    r:0,  c:7,  d:\'D\', q:\'Berpindah dari Makkah ke Madinah demi menegakkan agama\'},\n  {w:\'AUS\',       r:4,  c:2,  d:\'D\', q:\'Salah satu suku Ansar di Madinah bersama suku Khazraj\'},\n  {w:\'PIAGAM\',    r:6,  c:8,  d:\'D\', q:\'Perjanjian damai antar penduduk Madinah\'},\n  {w:\'IMAN\',      r:8,  c:12, d:\'D\', q:\'Modal yang dibawa Muhajirin saat hijrah: ... kepada Allah\'},\n]});\n</script>\n';
